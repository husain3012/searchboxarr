{
  "name": "searchboxarr",
  "version": "1.2.2",
  "private": true,
  "description": "Prowlarr-powered torrent search UI",
  "type": "module",
  "scripts": {
    "install:all": "npm install --prefix backend && npm install --prefix frontend",
    "build:frontend": "npm run build --prefix frontend",
    "build:backend": "npm run build --prefix backend",
    "build": "npm run build:frontend && npm run build:backend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:frontend": "npm run dev --prefix frontend",
    "start": "npm run start --prefix backend",
    "docker:build": "docker build -t searchboxarr:latest .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f searchboxarr",
    "lint": "npm run lint --prefix backend && npm run lint --prefix frontend",
    "test": "echo \"No tests defined yet\" && exit 0",
    "prepare": "husky"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "keywords": [
    "prowlarr",
    "torrent",
    "search",
    "arr",
    "indexer"
  ],
  "license": "MIT",
  "devDependencies": {
    "@commitlint/cli": "^20.5.0",
    "@commitlint/config-conventional": "^20.5.0",
    "@eslint/js": "^9.21.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/git": "^10.0.1",
    "eslint": "^9.21.0",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "semantic-release": "^25.0.3",
    "typescript-eslint": "^8.24.1"
  },
  "lint-staged": {
    "*.{ts,tsx,js,json,md}": [
      "prettier --write"
    ],
    "backend/src/**/*.ts": [
      "eslint --fix"
    ],
    "frontend/src/**/*.{ts,tsx}": [
      "eslint --fix"
    ]
  }
}
