# ╔══════════════════════════════════════════════════════╗
# ║          Searchboxarr — Environment Variables        ║
# ║   Copy this file to .env and fill in your values     ║
# ╚══════════════════════════════════════════════════════╝

# ── REQUIRED ─────────────────────────────────────────────
# Your Prowlarr API key (Settings → General → API Key)
PROWLARR_API_KEY=f467968965bd4556bbff0413cd2df3d5

# ── Prowlarr Connection ───────────────────────────────────
# URL of your Prowlarr instance
# If Searchboxarr runs in the same Docker network as Prowlarr, use the service name
PROWLARR_URL=http://homeserver-alpha15:3050

# Request timeout in ms
PROWLARR_TIMEOUT=30000

# ── Network ───────────────────────────────────────────────
# Host port to expose Searchboxarr on
SEARCHBOXARR_HOST_PORT=9797

# Base URL if running behind a reverse proxy at a sub-path
# e.g. SEARCHARR_BASE_URL=/searchboxarr
SEARCHARR_BASE_URL=/

# Set to true if behind nginx/traefik/caddy
TRUST_PROXY=false

# ── Cache ─────────────────────────────────────────────────
CACHE_ENABLED=true
# Default TTL in seconds
CACHE_TTL=300
# Max number of cached entries
CACHE_MAX_SIZE=500
# TTL for search results
CACHE_SEARCH_TTL=120
# TTL for indexer list
CACHE_INDEXERS_TTL=600

# ── Rate Limiting ─────────────────────────────────────────
RATE_LIMIT_ENABLED=true
# Window size in ms (default: 1 minute)
RATE_LIMIT_WINDOW_MS=60000
# Max requests per IP per window
RATE_LIMIT_MAX=60

# ── Basic Auth (optional) ─────────────────────────────────
AUTH_ENABLED=false
AUTH_USERNAME=searchboxarr
AUTH_PASSWORD=

# ── Search Settings ───────────────────────────────────────
RESULTS_PER_PAGE=25
MAX_RESULTS=100

# ── Logging ───────────────────────────────────────────────
# Levels: error, warn, info, http, debug
LOG_LEVEL=info
# Morgan format: combined, common, short, tiny
LOG_FORMAT=short

# ── Timezone ──────────────────────────────────────────────
TZ=UTC
